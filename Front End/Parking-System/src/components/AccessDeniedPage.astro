---
const API_URL = import.meta.env.PUBLIC_API_URL;

const portalTransition = {
  forwards: {
    old: {
      name: "portal-old-forward",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
    new: {
      name: "portal-new-forward",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
  },
  backwards: {
    old: {
      name: "portal-old-back",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
    new: {
      name: "portal-new-back",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
  },
};
---

<div
  id="access-denied-page"
  data-api-url={API_URL}
  class="bg-[#0b1326] font-['Inter'] text-[#dae2fd] min-h-screen selection:bg-[#0f69dc] selection:text-[#ecf0ff] overflow-hidden"
>
  <main
    transition:animate={portalTransition}
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#0f69dc]/10 rounded-full blur-[120px] animate-pulse [animation-duration:6s]"
      ></div>
    </div>

    <div
      data-denied-main
      class="relative z-10 w-full max-w-4xl px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center opacity-0 translate-y-6 blur-sm transition-all duration-1000 ease-out"
    >
      <div class="lg:col-span-7 flex flex-col items-start space-y-6">
        <div class="space-y-1">
          <span class="text-sm uppercase tracking-[0.2em] text-[#adc6ff] font-bold">
            Error Protocol 403
          </span>

          <h1 class="text-8xl md:text-9xl font-black tracking-tighter text-[#dae2fd] [text-shadow:0_0_40px_rgba(173,198,255,0.3)]">
            Access <br /> Denied
          </h1>
        </div>

        <p class="text-[#c3c6d7] text-lg md:text-xl max-w-md leading-relaxed">
          You have encountered a restricted perimeter. Your credentials do not possess the required
          clearance for this administrative sector.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            id="denied-back-link"
            href="/"
            class="bg-gradient-to-br from-[#adc6ff] to-[#0f69dc] text-[#002e6a] px-8 py-4 rounded-md font-bold flex items-center gap-3 transition-all hover:scale-[1.02] active:scale-95 shadow-xl shadow-[#060e20]/40"
          >
            <span class="material-symbols-outlined text-xl">arrow_back</span>
            <span id="denied-back-text">Back to Portal</span>
          </a>

          <button
            type="button"
            class="bg-[#2d3449] text-[#dae2fd] px-8 py-4 rounded-md font-bold flex items-center gap-3 transition-all hover:bg-[#31394d] hover:scale-[1.02] active:scale-95"
          >
            <span class="material-symbols-outlined text-xl">mail</span>
            Contact Support
          </button>
        </div>
      </div>

      <div class="lg:col-span-5 hidden lg:block">
        <div
          data-denied-side
          class="bg-[#131b2e] rounded-xl p-8 border border-[#434655]/15 relative overflow-hidden opacity-0 translate-x-8 blur-sm transition-all duration-[1200ms] ease-out"
        >
          <div class="absolute top-0 right-0 p-4 opacity-10">
            <span class="material-symbols-outlined text-9xl" style="font-variation-settings: 'FILL' 1;">
              lock
            </span>
          </div>

          <div class="relative z-10 space-y-8">
            <div>
              <h3 class="text-[#adc6ff] font-bold uppercase tracking-wider text-xs mb-4">
                Security Incident Log
              </h3>

              <div class="space-y-3">
                <div class="bg-[#171f33] p-3 rounded-lg flex items-center justify-between">
                  <span class="text-xs text-[#c3c6d7]">TIMESTAMP</span>
                  <span id="security-timestamp" class="text-xs font-bold text-[#dae2fd]">--</span>
                </div>

                <div class="bg-[#171f33] p-3 rounded-lg flex items-center justify-between">
                  <span class="text-xs text-[#c3c6d7]">IP_ADDRESS</span>
                  <span class="text-xs font-bold text-[#dae2fd]">192.168.1.104</span>
                </div>

                <div class="bg-[#171f33] p-3 rounded-lg flex items-center justify-between">
                  <span class="text-xs text-[#c3c6d7]">RESOURCE</span>
                  <span class="text-xs font-bold text-[#dae2fd]">/admin/vault_7</span>
                </div>
              </div>
            </div>

            <div class="pt-4 border-t border-[#434655]/15">
              <h3 class="text-[#dae2fd] font-bold text-sm mb-2">Instructions for Retrieval</h3>
              <p class="text-[#c3c6d7] text-sm leading-snug">
                If you believe this is an error, please reach out to your system architect. Quote the
                <span class="text-[#adc6ff]">Reference ID: OX-9921</span>
                for expedited resolution.
              </p>
            </div>

            <div class="flex items-center gap-4 bg-[#3a4a5f]/20 p-4 rounded-lg border border-[#3a4a5f]/30">
              <span class="material-symbols-outlined text-[#b7c8e1]">verified_user</span>

              <div class="text-xs">
                <p class="text-[#dae2fd] font-bold">Standard Shield Active</p>
                <p class="text-[#c3c6d7]">Identity verified but unauthorized.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <div
    data-denied-footer
    class="fixed bottom-0 left-0 w-full p-8 hidden md:flex justify-between items-end pointer-events-none opacity-0 translate-y-4 transition-all duration-1000 ease-out"
  >
    <div class="text-[#c3c6d7]/30 text-[10px] uppercase tracking-[0.4em] [writing-mode:vertical-lr] rotate-180">
      Obsidian Administrative Suite v4.0.2
    </div>

    <div class="flex flex-col items-end gap-2">
      <div class="w-12 h-[1px] bg-[#adc6ff]/30"></div>
      <div class="text-[#c3c6d7]/30 text-[10px] uppercase tracking-[0.4em]">
        System Health: Nominal
      </div>
    </div>
  </div>
</div>

<script is:inline>
  let deniedTimestampInterval;

  function formatSecurityTimestamp(date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    const hours = String(date.getHours()).padStart(2, "0");
    const minutes = String(date.getMinutes()).padStart(2, "0");
    const seconds = String(date.getSeconds()).padStart(2, "0");

    return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
  }

  function updateSecurityTimestamp() {
    const timestampElement = document.getElementById("security-timestamp");
    if (!timestampElement) return;
    timestampElement.textContent = formatSecurityTimestamp(new Date());
  }

  function setupAccessDeniedAnimation() {
    const main = document.querySelector("[data-denied-main]");
    const side = document.querySelector("[data-denied-side]");
    const footer = document.querySelector("[data-denied-footer]");

    requestAnimationFrame(() => {
      setTimeout(() => {
        main?.classList.remove("opacity-0", "translate-y-6", "blur-sm");
        main?.classList.add("opacity-100", "translate-y-0", "blur-0");
      }, 120);

      setTimeout(() => {
        side?.classList.remove("opacity-0", "translate-x-8", "blur-sm");
        side?.classList.add("opacity-100", "translate-x-0", "blur-0");
      }, 260);

      setTimeout(() => {
        footer?.classList.remove("opacity-0", "translate-y-4");
        footer?.classList.add("opacity-100", "translate-y-0");
      }, 360);
    });
  }

  async function setupDeniedBackButton() {
    const page = document.getElementById("access-denied-page");
    const apiUrl = page?.dataset.apiUrl;
    const backLink = document.getElementById("denied-back-link");
    const backText = document.getElementById("denied-back-text");

    if (!apiUrl || !backLink || !backText) return;

    try {
      const response = await fetch(`${apiUrl}/auth/refresh`, {
        method: "POST",
        credentials: "include",
      });

      if (response.ok) {
        backLink.href = "/dashboard";
        backText.textContent = "Back to Dashboard";
      } else {
        backLink.href = "/";
        backText.textContent = "Back to Portal";
      }
    } catch (error) {
      backLink.href = "/";
      backText.textContent = "Back to Portal";
    }
  }

  function setupSecurityTimestamp() {
    clearInterval(deniedTimestampInterval);
    updateSecurityTimestamp();
    deniedTimestampInterval = setInterval(updateSecurityTimestamp, 1000);
  }

  function setupAccessDeniedPage() {
    setupAccessDeniedAnimation();
    setupSecurityTimestamp();
    setupDeniedBackButton();
  }

  setupAccessDeniedPage();
  document.addEventListener("astro:page-load", setupAccessDeniedPage);
  document.addEventListener("astro:before-swap", () => {
    clearInterval(deniedTimestampInterval);
  });
</script>