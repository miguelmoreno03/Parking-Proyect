---
const API_URL = import.meta.env.PUBLIC_API_URL;

const portalTransition = {
  forwards: {
    old: {
      name: "portal-old-forward",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
    new: {
      name: "portal-new-forward",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
  },
  backwards: {
    old: {
      name: "portal-old-back",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
    new: {
      name: "portal-new-back",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
  },
};
---

<div
  id="dashboard-shell"
  data-api-url={API_URL}
  class="bg-[#0b1326] text-[#dae2fd] selection:bg-[#adc6ff] selection:text-[#002e6a] opacity-0 translate-y-3 blur-sm transition-all duration-500 ease-out"
>
  <!-- SideNavBar -->
  <aside
    id="dashboard-sidebar"
    class="fixed left-0 top-0 h-screen w-64 bg-[#131b2e] flex flex-col py-6 gap-2 font-['Inter'] uppercase tracking-[0.05em] text-[11px] opacity-0 -translate-x-4 transition-all duration-700 ease-out"
  >
    <div class="px-6 mb-8">
      <h1 class="text-lg font-black text-white leading-tight">Obsidian Suite</h1>
      <p class="text-[#adc6ff] opacity-80 tracking-widest">Parking Management</p>
    </div>

    <nav class="flex-1">
      <a class="bg-[#222a3d] text-[#adc6ff] rounded-md mx-2 px-4 py-3 flex items-center gap-3 transition-colors duration-300" href="#">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dashboard</span>
        <span>Dashboard</span>
      </a>

      <a class="text-[#c3c6d7] opacity-70 hover:opacity-100 hover:bg-[#171f33] hover:text-white mx-2 px-4 py-3 flex items-center gap-3 transition-colors duration-300" href="#">
        <span class="material-symbols-outlined">payments</span>
        <span>Rates</span>
      </a>

      <a class="text-[#c3c6d7] opacity-70 hover:opacity-100 hover:bg-[#171f33] hover:text-white mx-2 px-4 py-3 flex items-center gap-3 transition-colors duration-300" href="#">
        <span class="material-symbols-outlined">local_parking</span>
        <span>Space</span>
      </a>

      <a class="text-[#c3c6d7] opacity-70 hover:opacity-100 hover:bg-[#171f33] hover:text-white mx-2 px-4 py-3 flex items-center gap-3 transition-colors duration-300" href="#">
        <span class="material-symbols-outlined">group</span>
        <span>Users</span>
      </a>

      <a class="text-[#c3c6d7] opacity-70 hover:opacity-100 hover:bg-[#171f33] hover:text-white mx-2 px-4 py-3 flex items-center gap-3 transition-colors duration-300" href="#">
        <span class="material-symbols-outlined">confirmation_number</span>
        <span>Tickets</span>
      </a>
    </nav>

    <div class="mt-auto space-y-2">
      <button class="w-[calc(100%-1rem)] py-3 bg-[#3a4a5f] text-[#a9bad3] rounded-md flex items-center justify-center gap-2 font-bold hover:brightness-110 transition-all mx-2">
        <span class="material-symbols-outlined text-sm">monitor_heart</span>
        System Health
      </button>

      <button
        id="dashboard-logout"
        type="button"
        class="w-[calc(100%-1rem)] text-[#ffb4ab] rounded-md mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-[#ffb4ab]/10"
      >
        <span class="material-symbols-outlined">logout</span>
        <span>Logout</span>
      </button>
    </div>
  </aside>

  <!-- Main Content Area -->
  <main
    transition:animate={portalTransition}
    class="ml-64 min-h-screen flex flex-col"
  >
    <div class="p-8 space-y-8 w-full">
      <!-- Hero Insight Section -->
      <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-12">
        <div>
          <h2 class="text-4xl font-extrabold tracking-tight text-white mb-2">Command Center</h2>
          <p class="text-[#c3c6d7] max-w-md">
            Real-time oversight of ArchPark's administrative infrastructure and infrastructure status.
          </p>
        </div>

        <div class="flex gap-4">
          <div class="bg-[#131b2e] p-4 rounded-xl flex flex-col min-w-[140px]">
            <span class="text-[10px] uppercase tracking-widest text-[#adc6ff]/60 font-bold">Uptime</span>
            <span class="text-2xl font-black text-white">99.98%</span>
          </div>

          <div class="bg-[#131b2e] p-4 rounded-xl flex flex-col min-w-[140px]">
            <span class="text-[10px] uppercase tracking-widest text-[#adc6ff]/60 font-bold">Latency</span>
            <span class="text-2xl font-black text-white">12ms</span>
          </div>
        </div>
      </div>

      <!-- Bento Grid Dashboard -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <!-- Occupancy Gauge -->
        <div class="md:col-span-4 bg-[#131b2e] rounded-2xl p-6 relative overflow-hidden group">
          <div class="flex justify-between items-start mb-8">
            <div>
              <span class="text-[11px] font-bold tracking-widest text-[#adc6ff] uppercase">Space Control</span>
              <h3 class="text-2xl font-bold text-white">Occupancy</h3>
            </div>
            <span class="material-symbols-outlined text-[#adc6ff]">local_parking</span>
          </div>

          <div class="flex items-center justify-center py-4">
            <div class="relative w-40 h-40 flex items-center justify-center">
              <svg class="w-full h-full transform -rotate-90">
                <circle class="text-[#222a3d]" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-width="12"></circle>
                <circle class="text-[#0f69dc]" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-dasharray="440" stroke-dashoffset="110" stroke-width="12"></circle>
              </svg>

              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-4xl font-black text-white">75%</span>
                <span class="text-[10px] uppercase tracking-tighter text-[#c3c6d7]">Live Load</span>
              </div>
            </div>
          </div>

          <div class="mt-4 flex justify-between text-sm">
            <span class="text-[#c3c6d7]">Used: 1,420</span>
            <span class="text-[#c3c6d7]">Total: 1,900</span>
          </div>
        </div>

        <!-- Current Rates Card -->
        <div class="md:col-span-8 bg-[#171f33] rounded-2xl p-6 flex flex-col">
          <div class="flex justify-between items-center mb-6">
            <div>
              <span class="text-[11px] font-bold tracking-widest text-[#adc6ff] uppercase text-opacity-70">Rates Management</span>
              <h3 class="text-2xl font-bold text-white">Live Pricing</h3>
            </div>

            <div class="flex gap-2">
              <span class="bg-[#3a4a5f] text-[#a9bad3] px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                Peak
              </span>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 flex-1">
            <div class="bg-[#222a3d] p-5 rounded-xl border border-white/5 flex flex-col justify-between">
              <span class="text-[#c3c6d7] text-sm font-medium">Standard</span>
              <div>
                <div class="text-3xl font-black text-white">$4.50</div>
                <div class="text-xs text-[#c3c6d7]">per 30 mins</div>
              </div>
            </div>

            <div class="bg-[#222a3d] p-5 rounded-xl border border-white/5 flex flex-col justify-between">
              <span class="text-[#c3c6d7] text-sm font-medium">Premium</span>
              <div>
                <div class="text-3xl font-black text-white">$8.00</div>
                <div class="text-xs text-[#c3c6d7]">per 30 mins</div>
              </div>
            </div>

            <div class="bg-[#0f69dc] p-5 rounded-xl flex flex-col justify-between text-[#ecf0ff]">
              <span class="text-[#ecf0ff]/70 text-sm font-bold uppercase tracking-tighter">Valet</span>
              <div>
                <div class="text-3xl font-black">$15.00</div>
                <div class="text-xs text-[#ecf0ff]/60">flat fee</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Tickets List -->
        <div class="md:col-span-7 bg-[#131b2e] rounded-2xl p-6">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-white">Recent Ticket Logs</h3>
            <button class="text-[#adc6ff] text-xs font-bold hover:underline">View All Logs</button>
          </div>

          <div class="space-y-1">
            <div class="flex items-center justify-between py-4 px-4 bg-[#0b1326] rounded-lg">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-[#222a3d] flex items-center justify-center">
                  <span class="material-symbols-outlined text-[#adc6ff]">confirmation_number</span>
                </div>
                <div>
                  <div class="text-sm font-bold text-white">#TKT-8921</div>
                  <div class="text-xs text-[#c3c6d7]">Bay 42 - Entry Scan</div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-white">08:14 AM</div>
                <div class="text-[10px] text-green-400 font-bold uppercase">Success</div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 px-4 hover:bg-[#222a3d] rounded-lg transition-colors">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-[#222a3d] flex items-center justify-center">
                  <span class="material-symbols-outlined text-[#adc6ff]">confirmation_number</span>
                </div>
                <div>
                  <div class="text-sm font-bold text-white">#TKT-8920</div>
                  <div class="text-xs text-[#c3c6d7]">Bay 12 - Lost Ticket Recovery</div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-white">08:02 AM</div>
                <div class="text-[10px] text-[#ffb4ab] font-bold uppercase">Escalated</div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 px-4 bg-[#0b1326] rounded-lg">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-[#222a3d] flex items-center justify-center">
                  <span class="material-symbols-outlined text-[#adc6ff]">confirmation_number</span>
                </div>
                <div>
                  <div class="text-sm font-bold text-white">#TKT-8919</div>
                  <div class="text-xs text-[#c3c6d7]">Exit Gate 2 - Validation</div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-white">07:55 AM</div>
                <div class="text-[10px] text-green-400 font-bold uppercase">Success</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Active User Count -->
        <div class="md:col-span-5 bg-[#171f33] rounded-2xl p-6 relative overflow-hidden">
          <div class="relative z-10">
            <span class="text-[11px] font-bold tracking-widest text-[#adc6ff] uppercase">User Directory</span>
            <h3 class="text-2xl font-bold text-white mt-1">Active Accounts</h3>

            <div class="mt-8 flex items-end gap-2">
              <span class="text-6xl font-black text-white leading-none">842</span>
              <span class="text-green-400 font-bold mb-1">+12%</span>
            </div>

            <p class="text-sm text-[#c3c6d7] mt-2">Active sessions across all kiosks</p>

            <div class="mt-8 grid grid-cols-2 gap-4">
              <div class="flex flex-col">
                <span class="text-[10px] text-[#c3c6d7] uppercase font-bold">New Today</span>
                <span class="text-lg font-bold text-white">34</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] text-[#c3c6d7] uppercase font-bold">Support Calls</span>
                <span class="text-lg font-bold text-white">5</span>
              </div>
            </div>
          </div>

          <!-- Se restaura tal cual el elemento decorativo original -->
          <div class="absolute -right-8 -bottom-8 w-48 h-48 opacity-10">
            <span class="material-symbols-outlined text-[12rem] text-[#adc6ff]" style="font-variation-settings: 'FILL' 1;">group</span>
          </div>
        </div>

        <!-- Footer Stats -->
        <div class="md:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
          <div class="bg-[#131b2e] p-4 rounded-xl flex items-center gap-3 border-l-4 border-[#adc6ff]">
            <span class="material-symbols-outlined text-[#adc6ff] text-xl">database</span>
            <div>
              <div class="text-[10px] uppercase font-black text-[#c3c6d7]">Core API</div>
              <div class="text-sm font-bold text-white">Operational</div>
            </div>
          </div>

          <div class="bg-[#131b2e] p-4 rounded-xl flex items-center gap-3 border-l-4 border-[#adc6ff]">
            <span class="material-symbols-outlined text-[#adc6ff] text-xl">payments</span>
            <div>
              <div class="text-[10px] uppercase font-black text-[#c3c6d7]">Stripe Gateway</div>
              <div class="text-sm font-bold text-white">Connected</div>
            </div>
          </div>

          <div class="bg-[#131b2e] p-4 rounded-xl flex items-center gap-3 border-l-4 border-[#adc6ff]">
            <span class="material-symbols-outlined text-[#adc6ff] text-xl">sensors</span>
            <div>
              <div class="text-[10px] uppercase font-black text-[#c3c6d7]">IoT Network</div>
              <div class="text-sm font-bold text-white">Active</div>
            </div>
          </div>

          <div class="bg-[#131b2e] p-4 rounded-xl flex items-center gap-3 border-l-4 border-[#ffb4ab]">
            <span class="material-symbols-outlined text-[#ffb4ab] text-xl">warning</span>
            <div>
              <div class="text-[10px] uppercase font-black text-[#c3c6d7]">Backup Hub</div>
              <div class="text-sm font-bold text-white">Standby</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script is:inline>
  function setupDashboardEntryAnimation() {
    const shell = document.getElementById("dashboard-shell");
    const sidebar = document.getElementById("dashboard-sidebar");

    requestAnimationFrame(() => {
      shell?.classList.remove("opacity-0", "translate-y-3", "blur-sm");
      shell?.classList.add("opacity-100", "translate-y-0", "blur-0");

      setTimeout(() => {
        sidebar?.classList.remove("opacity-0", "-translate-x-4");
        sidebar?.classList.add("opacity-100", "translate-x-0");
      }, 120);
    });
  }

  function setupDashboardLogout() {
    const page = document.getElementById("dashboard-shell");
    const apiUrl = page?.dataset.apiUrl;
    const logoutButton = document.getElementById("dashboard-logout");

    if (!apiUrl || !logoutButton || logoutButton.dataset.bound === "true") return;

    logoutButton.dataset.bound = "true";

    logoutButton.addEventListener("click", async () => {
      page?.classList.remove("opacity-100", "translate-y-0", "blur-0");
      page?.classList.add("opacity-0", "translate-y-2", "blur-sm");

      try {
        await new Promise((resolve) => setTimeout(resolve, 260));

        await fetch(`${apiUrl}/auth/logout`, {
          method: "POST",
          credentials: "include",
        });
      } catch (error) {
        console.error("Logout error:", error);
      } finally {
        window.location.replace("/");
      }
    });
  }

  function setupDashboardPage() {
    setupDashboardEntryAnimation();
    setupDashboardLogout();
  }

  setupDashboardPage();
  document.addEventListener("astro:page-load", setupDashboardPage);
</script>