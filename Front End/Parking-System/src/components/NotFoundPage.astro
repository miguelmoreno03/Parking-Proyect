---
const API_URL = import.meta.env.PUBLIC_API_URL;

const portalTransition = {
  forwards: {
    old: {
      name: "portal-old-forward",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
    new: {
      name: "portal-new-forward",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
  },
  backwards: {
    old: {
      name: "portal-old-back",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
    new: {
      name: "portal-new-back",
      duration: "1.1s",
      easing: "cubic-bezier(0.16, 1, 0.3, 1)",
      fillMode: "both",
    },
  },
};
---

<div class="bg-[#0b1326] text-[#dae2fd] min-h-screen flex flex-col overflow-hidden font-['Inter']">
  <main
    transition:animate={portalTransition}
    class="flex-grow flex items-center justify-center relative px-6"
  >
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] rounded-full bg-[#adc6ff]/5 blur-[120px]"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] rounded-full bg-[#3a4a5f]/10 blur-[100px]"></div>

      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(#adc6ff 1px, transparent 1px), linear-gradient(90deg, #adc6ff 1px, transparent 1px); background-size: 80px 80px;"
      ></div>
    </div>

    <div
      data-notfound-main
      class="relative z-10 w-full max-w-4xl grid md:grid-cols-12 gap-12 items-center opacity-0 translate-y-6 blur-sm transition-all duration-1000 ease-out"
    >
      <div class="md:col-span-5 flex flex-col items-center md:items-start space-y-4">
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-[#3a4a5f]/30 border border-[#434655]/15">
          <span class="material-symbols-outlined text-sm text-[#adc6ff]">error</span>
          <span class="text-[10px] font-bold tracking-[0.1em] text-[#a9bad3] uppercase">
            System Exception
          </span>
        </div>

        <h1
          class="text-[120px] md:text-[180px] font-black leading-none tracking-tighter select-none"
          style="background: linear-gradient(135deg, #adc6ff 0%, #0f69dc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
        >
          404
        </h1>

        <div class="h-1 w-24 bg-[#adc6ff]/20 rounded-full"></div>
      </div>

      <div class="md:col-span-7 text-center md:text-left space-y-8">
        <div class="space-y-4">
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-[#dae2fd]">
            Lost in the Void
          </h2>

          <p class="text-lg text-[#c3c6d7] max-w-lg leading-relaxed">
            The page you are looking for has been moved or does not exist. Our administrative terminal is unable to locate the requested resource.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center md:items-start gap-4">
          <a
            id="notfound-return-link"
            href="/"
            class="group relative inline-flex w-auto min-w-[260px] whitespace-nowrap px-8 py-4 bg-gradient-to-br from-[#adc6ff] to-[#0f69dc] text-[#002e6a] font-bold rounded-lg transition-all active:scale-95 shadow-lg shadow-[#0f69dc]/20 overflow-hidden justify-center"
          >
            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <span class="relative flex items-center gap-2 whitespace-nowrap">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
              <span id="notfound-return-text">Return to Portal</span>
             
            </span>
          </a>

          <button
            type="button"
            class="inline-flex w-auto min-w-[210px] whitespace-nowrap bg-[#2d3449] text-[#dae2fd] px-8 py-4 rounded-md font-bold items-center justify-center gap-3 transition-all hover:bg-[#31394d] hover:scale-[1.02] active:scale-95"
          >
            <span class="material-symbols-outlined text-xl">mail</span>
            Contact Support
          </button>
        </div>

        <div class="pt-8 flex flex-wrap gap-3 justify-center md:justify-start">
          <div class="inline-flex items-center px-3 py-1.5 rounded-md bg-[#222a3d] border border-[#434655]/10">
            <span
              id="notfound-path"
              class="text-[10px] text-[#c3c6d7] tracking-wider uppercase"
            >
              Path: /
            </span>
          </div>

          <div class="inline-flex items-center px-3 py-1.5 rounded-md bg-[#222a3d] border border-[#434655]/10">
            <span class="text-[10px] text-[#c3c6d7] tracking-wider uppercase">
              Status: 0xCF04
            </span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer
    data-notfound-footer
    class="p-8 flex justify-between items-end opacity-0 translate-y-4 transition-all duration-1000 ease-out"
  >
    <div class="flex flex-col">
      <span class="text-[10px] tracking-widest uppercase text-[#c3c6d7]">
        ParqMaster Terminal
      </span>
      <span class="text-[10px] tracking-widest uppercase text-[#c3c6d7]">
        Admin Suite v4.2.0
      </span>
    </div>

    <div class="flex space-x-4">
      <div class="w-12 h-[2px] bg-[#434655]/30"></div>
      <div class="w-24 h-[2px] bg-[#adc6ff]/20"></div>
    </div>
  </footer>
</div>

<script is:inline define:vars={{ API_URL }}>
  function setupNotFoundAnimation() {
    const main = document.querySelector("[data-notfound-main]");
    const footer = document.querySelector("[data-notfound-footer]");

    requestAnimationFrame(() => {
      setTimeout(() => {
        main?.classList.remove("opacity-0", "translate-y-6", "blur-sm");
        main?.classList.add("opacity-100", "translate-y-0", "blur-0");
      }, 120);

      setTimeout(() => {
        footer?.classList.remove("opacity-0", "translate-y-4");
        footer?.classList.add("opacity-100", "translate-y-0");
      }, 320);
    });
  }

  async function setupNotFoundState() {
    const pathElement = document.getElementById("notfound-path");
    const returnLink = document.getElementById("notfound-return-link");
    const returnText = document.getElementById("notfound-return-text");

    if (pathElement) {
      pathElement.textContent = `Path: ${window.location.pathname}`;
    }

    if (!returnLink || !returnText) return;

    try {
      const response = await fetch(`${API_URL}/auth/refresh`, {
        method: "POST",
        credentials: "include",
      });

      if (response.ok) {
        returnLink.href = "/dashboard";
        returnText.textContent = "Return to Dashboard";
      } else {
        returnLink.href = "/";
        returnText.textContent = "Return to Portal";
      }
    } catch (error) {
      returnLink.href = "/";
      returnText.textContent = "Return to Portal";
    }
  }

  function setupNotFoundPage() {
    setupNotFoundAnimation();
    setupNotFoundState();
  }

  setupNotFoundPage();
  document.addEventListener("astro:page-load", setupNotFoundPage);
</script>