---
import Layout from "../layouts/Layout.astro";
import LoginPage from "../components/LoginPage.astro";

const API_URL = import.meta.env.PUBLIC_API_URL;
---

<Layout>
  <div id="login-route" data-api-url={API_URL}>
    <LoginPage />
  </div>
</Layout>

<script is:inline>
  async function protectLoginRoute() {
    const route = document.getElementById("login-route");
    const apiUrl = route?.dataset.apiUrl;

    if (!route || !apiUrl) return;

    try {
      const response = await fetch(`${apiUrl}/auth/refresh`, {
        method: "POST",
        credentials: "include",
      });

      if (response.ok) {
        window.location.href = "/dashboard";
      }
    } catch (error) {
      console.error("Login route guard error:", error);
    }
  }

  protectLoginRoute();
  document.addEventListener("astro:page-load", protectLoginRoute);
</script>